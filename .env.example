# Copia este archivo a ".env" y completa con tus datos reales.
# No subas .env al repositorio — contiene credenciales.

SFTP_HOST=sftp.ejemplo.com
SFTP_PORT=22
SFTP_USER=miusuario
SFTP_PASS=mipassword

# Ruta ABSOLUTA donde se guardarán las descargas.
# En Windows usa rutas con \ como en el ejemplo.
LOCAL_DOWNLOAD_ROOT=C:\Users\tuusuario\Downloads\sftp_pulls

# Número de descargas en paralelo (entre 1 y 16).
MAX_WORKERS=4

# Tiempo máximo de espera para conectar al servidor (segundos).
CONNECT_TIMEOUT=10
